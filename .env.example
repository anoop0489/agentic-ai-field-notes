# =============================================================================
# LangChain Learning Notes - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit your .env file to source control.
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# --- LangSmith (Observability & Tracing) ---
# Sign up at: https://smith.langchain.com/
# Set to "false" if behind a corporate proxy or to skip tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Tavily (Search API for Agents) ---
# Sign up at: https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# --- SQL Server (SQL Agent Demo) ---
# Raw ODBC connection string used by 02-gist-of-langchain/src/sql_demo.py
# Requires: ODBC Driver 17 for SQL Server installed locally
SQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-server.com;DATABASE=YourDatabase;UID=your-user;PWD=your-password;TrustServerCertificate=Yes;MultipleActiveResultSets=True;

# --- Pinecone (Vector Store for RAG) ---
# Sign up at: https://pinecone.io/ (free tier available)
# Create an index with: dimensions=1536, metric=cosine, type=dense
# IMPORTANT: LangChain looks for this exact env var name automatically
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxx
INDEX_NAME=medium-blogs-embeddings-index
